&lt;li&gt;Added Cursor IDE &quot;command&quot; files  &lt;a class=&quot;commit-link&quot; data-hovercard-type=&quot;commit&quot; data-hovercard-url=&quot;https://github.com/yairEO/tagify/commit/292a53542c08ac7c11ffe9bc99f459a7c6717a86/hovercard&quot; href=&quot;https://github.com/yairEO/tagify/commit/292a53542c08ac7c11ffe9bc99f459a7c6717a86&quot;&gt;&lt;tt&gt;292a535&lt;/tt&gt;&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;chore(package): require Node 22 and pnpm 10; bump dev tooling  &lt;a class=&quot;commit-link&quot; data-hovercard-type=&quot;commit&quot; data-hovercard-url=&quot;https://github.com/yairEO/tagify/commit/6bfc4e1790f6fe5dc72cca42b292c667b2a8b7d6/hovercard&quot; href=&quot;https://github.com/yairEO/tagify/commit/6bfc4e1790f6fe5dc72cca42b292c667b2a8b7d6&quot;&gt;&lt;tt&gt;6bfc4e1&lt;/tt&gt;&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;Bump rollup from 2.79.2 to 2.80.0  &lt;a class=&quot;commit-link&quot; data-hovercard-type=&quot;commit&quot; data-hovercard-url=&quot;https://github.com/yairEO/tagify/commit/e3ad3ade08083c43aae8fa6c2d59dd25ec7cb776/hovercard&quot; href=&quot;https://github.com/yairEO/tagify/commit/e3ad3ade08083c43aae8fa6c2d59dd25ec7cb776&quot;&gt;&lt;tt&gt;e3ad3ad&lt;/tt&gt;&lt;/a&gt;&lt;/li&gt;
