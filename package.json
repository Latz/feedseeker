{
	"name": "feedseeker",
	"version": "1.0.4",
	"description": "FeedSeeker - Find RSS, Atom, and JSON feeds on any website.",
	"type": "module",
	"bin": {
		"feed-seeker": "dist/feedseeker-cli.cjs"
	},
	"exports": {
		".": {
			"types": "./dist/types/feed-seeker.d.ts",
			"import": "./dist/feedseeker.js",
			"require": "./dist/feedseeker.cjs"
		},
		"./cli": {
			"types": "./dist/types/feed-seeker-cli.d.ts",
			"import": "./dist/feedseeker-cli.js",
			"require": "./dist/feedseeker-cli.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rimraf dist",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write \"**/*.{ts,js,json,md}\"",
		"format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
		"validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
		"prebuild": "pnpm run clean && pnpm run typecheck",
		"build": "pnpm run build:lib && pnpm run build:cli && pnpm run build:types",
		"build:lib": "vite build",
		"build:cli": "BUILD_TARGET=cli vite build",
		"build:types": "tsc --emitDeclarationOnly --declarationDir dist/types",
		"prepublishOnly": "pnpm run typecheck && pnpm run build && pnpm test",
		"prepare": "husky"
	},
	"keywords": [
		"rss",
		"atom",
		"feed",
		"finder",
		"rss-finder",
		"feed-discovery",
		"web-feed",
		"syndication",
		"query-parameters",
		"typescript",
		"feed-detector",
		"rss-detector",
		"atom-feed",
		"json-feed"
	],
	"author": "Latz <latz@elektroelch.de>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Latz/feedseeker.git"
	},
	"bugs": {
		"url": "https://github.com/Latz/feedseeker/issues"
	},
	"homepage": "https://github.com/Latz/feedseeker#readme",
	"dependencies": {
		"async": "^3.2.6",
		"commander": "^14.0.1",
		"linkedom": "^0.18.12",
		"tldts": "^7.4.2",
		"truncate-url": "^3.0.0",
		"undici": "^8.4.1"
	},
	"devDependencies": {
		"@eslint/js": "9.39.2",
		"@types/async": "^3.2.25",
		"@types/node": "^25.9.3",
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@typescript-eslint/parser": "^8.61.0",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"fast-check": "^4.8.0",
		"husky": "^9.1.7",
		"knip": "^6.16.1",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"lint-staged": {
		"*.{ts,js}": [
			"eslint --fix"
		]
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
