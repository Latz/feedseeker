{
	"name": "feedseeker",
	"version": "1.0.0",
	"description": "FeedSeeker - Find RSS, Atom, and JSON feeds on any website with support for preserving query parameters",
	"type": "module",
	"bin": {
		"feed-seeker": "dist/feed-seeker-cli.cjs"
	},
	"exports": {
		".": {
			"types": "./dist/types/feed-seeker.d.ts",
			"import": "./dist/feed-seeker.js",
			"require": "./dist/feed-seeker.cjs"
		},
		"./cli": {
			"types": "./dist/types/feed-seeker-cli.d.ts",
			"import": "./dist/feed-seeker-cli.js",
			"require": "./dist/feed-seeker-cli.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rimraf dist",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write \"**/*.{ts,js,json,md}\"",
		"format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
		"validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
		"prebuild": "pnpm run clean && pnpm run typecheck",
		"build": "pnpm run build:lib && pnpm run build:cli && pnpm run build:types",
		"build:lib": "vite build",
		"build:cli": "BUILD_TARGET=cli vite build",
		"build:types": "tsc --emitDeclarationOnly --declarationDir dist/types",
		"prepublishOnly": "pnpm run typecheck && pnpm run build && pnpm test",
		"prepare": "husky"
	},
	"keywords": [
		"rss",
		"atom",
		"feed",
		"finder",
		"rss-finder",
		"feed-discovery",
		"web-feed",
		"syndication",
		"query-parameters",
		"typescript",
		"feed-detector",
		"rss-detector",
		"atom-feed",
		"json-feed"
	],
	"author": "Latz <latz@elektroelch.de>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Latz/feed-seeker.git"
	},
	"bugs": {
		"url": "https://github.com/Latz/feed-seeker/issues"
	},
	"homepage": "https://github.com/Latz/feed-seeker#readme",
	"dependencies": {
		"async": "^3.2.6",
		"commander": "^14.0.1",
		"linkedom": "^0.18.7",
		"tldts": "^7.0.16",
		"truncate-url": "^3.0.0",
		"undici": "^7.24.1"
	},
	"devDependencies": {
		"@types/async": "^3.2.25",
		"@types/node": "^22.19.1",
		"@typescript-eslint/eslint-plugin": "^8.49.0",
		"@typescript-eslint/parser": "^8.49.0",
		"@vitest/coverage-v8": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"rimraf": "^5.0.10",
		"typescript": "^5.9.3",
		"vite": "^7.1.7",
		"vitest": "^4.0.15"
	},
	"lint-staged": {
		"*.{ts,js}": [
			"eslint --fix"
		]
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
